# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Local development (PostgreSQL running on your machine):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startup_digest"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/startup_digest"
# Production (Supabase):
#   DATABASE_URL = pooled string (port 6543) — REQUIRED params for Prisma + serverless:
#     ...pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = direct string (port 5432) — used only for `prisma migrate deploy`:
#     ...db.[ref].supabase.co:5432/postgres
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ----------------------------------------------------------------------------
# Product Hunt GraphQL API
# Get a developer token at https://www.producthunt.com/v2/oauth/applications
# ----------------------------------------------------------------------------
PRODUCT_HUNT_ACCESS_TOKEN=""

# ----------------------------------------------------------------------------
# OpenRouter (https://openrouter.ai/keys)
# ----------------------------------------------------------------------------
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"

# ----------------------------------------------------------------------------
# Resend (https://resend.com/api-keys)
# ----------------------------------------------------------------------------
RESEND_API_KEY=""
# Where the weekly digest is delivered:
DIGEST_EMAIL_TO="you@example.com"
# Verified sender (optional — defaults to onboarding@resend.dev for testing):
DIGEST_EMAIL_FROM="Startup Digest <onboarding@resend.dev>"

# ----------------------------------------------------------------------------
# Security & app
# ----------------------------------------------------------------------------
# Shared secret used to protect cron + manual API routes. Use a long random string.
CRON_SECRET=""
# Public base URL of the app (used for links in emails). No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# App auth (single-user gate over the dashboard + server actions)
# ----------------------------------------------------------------------------
# Password you type at /login. REQUIRED in production (leave empty locally to
# keep the app open for fast dev).
APP_PASSWORD=""
# Random server secret used to sign the auth cookie. Use a long random string.
AUTH_SECRET=""
